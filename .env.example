# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# Your GCP project ID (visible in the GCP console top bar)
GCP_PROJECT_ID=your-project-id

# Region for Vertex AI API calls
# gemini-2.5-flash is available in us-central1
GCP_REGION=us-central1

# Cloud Storage bucket name (must be globally unique across all of GCP)
# Created automatically by infra/setup_project.py
GCS_BUCKET=your-globally-unique-bucket-name
